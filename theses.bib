@mastersthesis{enoksen2026msc,
  abstract = {I denne oppgaven skal vi utvikle en metode for å estimere linse potensialet fra et sett av roulette amplituder. Denne oppgaven er laget som en del av CosmoAI prosjektet, som sikter på å bruke maskinlæring for å finne utspredningen av mørk materie skyer gjennom universet med bruk av gravitasjonell lensing. Vi gjør dette med å estimere et sett av roulette amplituder fra bilder av galakser som har lyset forvrengt av gravitasjonell lensing. Fra disse roulette amplitudene, sikter vi på å beskrive den gravitasjonelle lensen, og det er akkurat dette som er hovedmålet med denne oppgaven. For å oppnå målet vårt så vill vi bruke en modellbasert framgang til å bruke en regresjons analyse for å tilpasse en linse modell til et sett av roulette amplituder. Vi tester så denne metoden opp mot støy fra de foreløpige beste maskinlærings estimatene av roulette amplituder for å se om den er funksjonell i praksis.},
  author = {Enoksen, Martin Holten},
  month = {dec},
  note = {nva type: DegreeMaster},
  nva_api = {https://api.nva.unit.no/publication/019d710aa9cb-88ccd5c9-505e-4abf-9649-7f6c75f71588},
  school = {Norges teknisk-naturvitenskapelige universitet},
  title = {Reconstructing a lens potential from a set of Roulette Amplitudes},
  url = {https://api.nva.unit.no/publication/019d710aa9cb-88ccd5c9-505e-4abf-9649-7f6c75f71588},
  year = {2025}
}
@mastersthesis{hanssen2024msc,
  abstract = {In this thesis we will explore the novelty and potential of the Roulette formalism, and further its implementation in a gravitational lensing simulator, called CosmoSim. The Roulette formalism is a fairly new gravitational lensing framework which uses weak lensing techniques to describe strong lensing. This formalism will be our main focus as we explore similarities and differences with “lower-order” lensing approaches. We will also explore the possibility of using the Roulette formalism to describe cluster lensing. Lastly, we will check whether or not the Roulette formalism suffers from the same degeneracies as other weak lensing approaches.},
  author = {Elise Lindegaard Hanssen},
  note = {nva type: DegreeMaster},
  nva_api = {https://api.nva.unit.no/publication/0198e9e11536-a34afca4-47ae-4fa1-af06-fe36b47f4828},
  school = {Norges teknisk-naturvitenskapelige universitet},
  title = {The Roulette formalism - a weak lensing approach to strong lensing},
  url = {https://api.nva.unit.no/publication/0198e9e11536-a34afca4-47ae-4fa1-af06-fe36b47f4828},
  year = {2024}
}
